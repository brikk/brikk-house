percent_rank	(SELECT arrayStringConcat(groupArray(toString(w)),',') FROM (SELECT percent_rank() OVER (ORDER BY x) w FROM (SELECT 1 AS x UNION ALL SELECT 2 UNION ALL SELECT 3)))	(SELECT string_agg(w::VARCHAR,',') FROM (SELECT percent_rank() OVER (ORDER BY x) w FROM (SELECT 1 AS x UNION ALL SELECT 2 UNION ALL SELECT 3)))
cume_dist	(SELECT arrayStringConcat(groupArray(toString(w)),',') FROM (SELECT cume_dist() OVER (ORDER BY x) w FROM (SELECT 1 AS x UNION ALL SELECT 2 UNION ALL SELECT 3)))	(SELECT string_agg(w::VARCHAR,',') FROM (SELECT cume_dist() OVER (ORDER BY x) w FROM (SELECT 1 AS x UNION ALL SELECT 2 UNION ALL SELECT 3)))
