trim_tab	trim(concat(char(9),'x',char(9)))	trim(chr(9)||'x'||chr(9))
trim_nl	trim(concat(char(10),'x',char(10)))	trim(chr(10)||'x'||chr(10))
ltrim_tab	trimLeft(concat(char(9),'x'))	ltrim(chr(9)||'x')
position_hn	position('abcabc','b')	strpos('abcabc','b')
position_in	position('b' IN 'abcabc')	position('b' IN 'abcabc')
instr_case	instr('abcABC','B')	instr('abcABC','B')
instr_case2	instr('Hello','h')	instr('Hello','h')
octet_len_vc	octet_length('abc')	octet_length('abc')
substringUTF8_emoji	substringUTF8('😀x',1,1)	substring('😀x',1,1)
